<?xml version="1.0"?>
<!--
  MoveIt no longer uses this file — see launch/moveit.launch.py, which loads
  $(find rbpodo_description)/robots/<model_id>.urdf.xacro directly.

  The old wrapper listed several top-level <xacro:arg/> siblings, which is not
  valid XML (only one document root is allowed) and made xacro fail with
  "junk after document element" around line 9.

  This minimal URDF remains so any stale launch or tutorial path still naming
  config/rbpodo.urdf.xacro gets a parseable file (not a useful robot).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rbpodo_moveit_config_unused_stub">
  <link name="unused_stub_link"/>
</robot>
